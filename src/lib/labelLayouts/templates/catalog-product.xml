<?xml version="1.0" encoding="UTF-8"?>
<!--
  YesWeigh categorized product pack label — matches shop product print reference.
  Size: 75 × 45.5 mm @ 203 dpi, gap 3.5 mm.

  No genuine-spare header banner. Meta row is model / approval / serial.

  Bindings:
    {{itemName}} {{sku}} {{qty}} {{mrp}}
    {{modelNumber}} {{approvalNumber}} {{serialNumber}} {{qrPayload}}
-->
<label
  id="catalog-product"
  name="Catalog Product"
  dpi="203"
  widthMm="75"
  heightMm="45.5"
  gapMm="3.5"
  padMm="1.2"
>
  <border radiusPx="8" strokePx="2" />

  <product-pack
    headerHeightPx="0"
    metaHeightPx="56"
    brandHeightPx="38"
    bodyGapPx="3"
    qrRatio="0.33"
  >
    <body>
      <fields labelMaxFontPx="17" valueMaxFontPx="22">
        <field icon="grid" label="ITEM NAME" value="{{itemName}}" />
        <field icon="barcode" label="SKU" value="{{sku}}" />
        <field icon="cubes" label="QTY" value="{{qty}}" />
        <field icon="rupee" label="MRP" sublabel="INCLUDING GST" value="{{mrp}}" />
      </fields>

      <qr-panel padPx="12">
        <qr field="qrPayload" fallbackField="sku" />
      </qr-panel>
    </body>

    <meta dividerStrokePx="1" labelFontPx="15" valueFontPx="24">
      <cell icon="gear" label="MODEL NUMBER" value="{{modelNumber}}" />
      <cell icon="shield" label="MODEL APPROVAL NO." value="{{approvalNumber}}" />
      <cell icon="barcode" label="SERIAL NUMBER" value="{{serialNumber}}" />
    </meta>

    <brand
      logoSrc="/yesweigh-mark.png"
      logoHeightPx="26"
      name="YESWEIGH"
      center="Interweighing Pvt Ltd"
      origin="MADE IN CHINA"
      dividers="false"
      nameMaxFontPx="20"
      centerMaxFontPx="18"
      originMaxFontPx="12"
    />
  </product-pack>
</label>
