<?xml version="1.0" encoding="UTF-8"?>
<!--
  YesWeigh Genuine Spare Part product label — text only, no inverted fills.
  Size: 75 × 45.5 mm @ 203 dpi, gap 3.5 mm.

  Bindings:
    {{itemName}} {{sku}} {{masterProduct}} {{masterSku}}
    {{qty}} {{mrp}} {{packedOn}} {{batchNo}} {{packedBy}} {{qcStatus}} {{qrPayload}}
-->
<label
  id="genuine-spare-product"
  name="Genuine Spare Product"
  dpi="203"
  widthMm="75"
  heightMm="45.5"
  gapMm="3.5"
  padMm="1.2"
>
  <border radiusPx="4" strokePx="2" />

  <product-pack
    headerHeightPx="62"
    footerHeightPx="56"
    originHeightPx="16"
    bodyGapPx="3"
    qrRatio="0.34"
  >
    <header dividerStrokePx="1.5">
      <brand-left>
        <title value="YESWEIGH" bold="true" maxFontPx="26" minFontPx="16" />
        <tagline value="Precision Weighing Solutions" maxFontPx="12" minFontPx="9" />
      </brand-left>
      <brand-right>
        <title value="GENUINE SPARE PART" bold="true" maxFontPx="16" minFontPx="11" />
        <badge value="QUALITY • RELIABILITY • TRUST" maxFontPx="11" minFontPx="8" />
      </brand-right>
    </header>

    <body dividerStrokePx="1.5">
      <fields colonAlign="true" labelMaxFontPx="12" valueMaxFontPx="14" rowMinPx="18">
        <field label="ITEM NAME" value="{{itemName}}" />
        <field label="SKU" value="{{sku}}" />
        <field label="MASTER ITEM NAME" value="{{masterProduct}}" />
        <field label="MASTER SKU" value="{{masterSku}}" />
        <field label="QTY" value="{{qty}}" />
        <field label="MRP (INCLUDING GST)" value="{{mrp}}" />
      </fields>

      <qr-panel padPx="4" caption="SCAN TO VIEW" captionFontPx="11">
        <qr field="qrPayload" fallbackField="sku" />
        <sku-pill value="SKU: {{sku}}" fontPx="12" />
      </qr-panel>
    </body>

    <footer dividerStrokePx="1.5" labelFontPx="10" valueFontPx="12">
      <cell label="PACKED ON" value="{{packedOn}}" style="text" />
      <cell label="QC DONE" value="{{qcStatus}}" style="text" />
      <cell label="BATCH NO." value="{{batchNo}}" style="text" />
      <cell label="PACKED BY" value="{{packedBy}}" style="text" />
    </footer>

    <origin value="MADE IN CHINA" fontPx="11" />
  </product-pack>
</label>
