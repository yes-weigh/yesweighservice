<?xml version="1.0" encoding="UTF-8"?>
<!--
  YesWeigh Genuine Spare Part product label — matches print reference.
  Size: 75 × 45.5 mm @ 203 dpi, gap 3.5 mm.

  Bindings:
    {{itemName}} {{sku}} {{qty}} {{mrp}}
    {{packedOn}} {{batchNo}} {{packedBy}} {{qrPayload}}
-->
<label
  id="genuine-spare-product"
  name="Genuine Spare Product"
  dpi="203"
  widthMm="75"
  heightMm="45.5"
  gapMm="3.5"
  padMm="1.2"
>
  <border radiusPx="8" strokePx="2" />

  <product-pack
    headerHeightPx="46"
    metaHeightPx="68"
    brandHeightPx="38"
    bodyGapPx="3"
    qrRatio="0.33"
    bannerRatio="0.70"
  >
    <header
      title="GENUINE SPARE PART"
      titleMaxFontPx="22"
      titleMinFontPx="14"
      slantPx="24"
    />

    <body>
      <fields labelMaxFontPx="17" valueMaxFontPx="22">
        <field icon="grid" label="ITEM NAME" value="{{itemName}}" />
        <field icon="barcode" label="SKU" value="{{sku}}" />
        <field icon="cubes" label="QTY" value="{{qty}}" />
        <field icon="rupee" label="MRP" sublabel="INCLUDING GST" value="{{mrp}}" />
      </fields>

      <qr-panel padPx="12">
        <qr field="qrPayload" fallbackField="sku" />
      </qr-panel>
    </body>

    <meta dividerStrokePx="1" labelFontPx="18" valueFontPx="18">
      <cell icon="calendar" label="PACKED ON" value="{{packedOn}}" />
      <cell icon="clipboard" label="BATCH NO." value="{{batchNo}}" />
      <cell icon="grid" label="PACKED BY" value="{{packedBy}}" />
    </meta>

    <brand
      logoSrc="/yesweigh-mark.png"
      logoHeightPx="26"
      name="YESWEIGH"
      center="GENUINE SPARE PART"
      origin="MADE IN CHINA"
      nameMaxFontPx="20"
      centerMaxFontPx="14"
      originMaxFontPx="12"
    />
  </product-pack>
</label>
