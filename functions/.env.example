# Copy to .env.yesweigh-service for local `firebase deploy --only functions`.
# CI sets ZOHO_ORGANIZATION_ID from GitHub Actions; ZOHO_WEBHOOK_SECRET is optional (empty skips signature checks).
ZOHO_ORGANIZATION_ID=your_zoho_org_id
ZOHO_WEBHOOK_SECRET=
# Yes Store → Zoho item custom field (optional; empty ID enables auto-discovery by API name / label)
ZOHO_ITEM_STORE_LOCATIONS_CF_ID=
ZOHO_ITEM_STORE_LOCATIONS_CF_LABEL=Yes Store Locations
ZOHO_ITEM_STORE_LOCATIONS_CF_API_NAME=cf_store_location
