rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return userDoc().role;
    }

    function isSuperAdmin() {
      return signedIn() && (role() == 'super_admin' || role() == 'admin');
    }

    function isStaff() {
      return signedIn() && role() == 'staff';
    }

    function isOpsUser() {
      return isSuperAdmin() || isStaff();
    }

    function isDealer() {
      return signedIn() && (role() == 'dealer' || role() == 'director');
    }

    function isActiveUser() {
      return signedIn() && userDoc().active != false;
    }

    function bootstrapOpen() {
      return !exists(/databases/$(database)/documents/appSettings/system)
        || get(/databases/$(database)/documents/appSettings/system).data.bootstrapComplete != true;
    }

    function staffCanManageRole(targetRole) {
      return targetRole == 'dealer' || targetRole == 'dealer_staff'
        || targetRole == 'director' || targetRole == 'director_staff';
    }

    function userDealerId(data) {
      return data.dealerId != null ? data.dealerId : data.directorId;
    }

    function isDealerStaffRole(r) {
      return r == 'dealer_staff' || r == 'director_staff';
    }

    function validLoginIdType(t) {
      return t == 'aadhar' || t == 'phone' || t == 'email';
    }

    function validLoginId(data) {
      return data.loginId is string
        && data.loginIdType is string
        && validLoginIdType(data.loginIdType)
        && (
          (data.loginIdType == 'aadhar' && data.loginId.size() == 12)
          || (data.loginIdType == 'phone' && data.loginId.size() == 10)
          || (data.loginIdType == 'email' && data.loginId.matches('^[^@]+@[^@]+\\.[^@]+$'))
        );
    }

    function validAadhar(data) {
      return validLoginId(data) || (data.aadhar is string && data.aadhar.size() == 12);
    }

    function loginIdUnchanged() {
      return !resource.data.keys().hasAny(['loginId'])
        || (request.resource.data.loginId == resource.data.loginId
            && request.resource.data.loginIdType == resource.data.loginIdType);
    }

    function validAadharId(aadhar) {
      return aadhar is string && aadhar.size() == 12;
    }

    match /appSettings/{docId} {
      allow read: if signedIn();
      allow write: if signedIn() && bootstrapOpen();
    }

    match /catalogProducts/{productId} {
      allow read: if true;
      allow write: if false;
    }

    match /catalogCategories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /catalogMeta/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /catalogProductSpareMap/{productId} {
      allow read: if true;
      allow write: if false;
    }

    match /zohoCustomers/{customerId} {
      allow read: if isOpsUser();
      allow write: if false;
    }

    match /kams/{kamId} {
      allow read: if isOpsUser();
      allow write: if false;
    }

    match /dealerSettings/{docId} {
      allow read: if isOpsUser();
      allow write: if false;
    }

    match /aadharIndex/{aadhar} {
      allow read: if isActiveUser() && (isOpsUser() || isDealer());
      allow create: if validAadharId(aadhar)
        && isActiveUser()
        && (isOpsUser() || isDealer())
        && request.resource.data.uid is string
        && request.resource.data.role is string;
      allow delete: if isSuperAdmin();
    }

    match /dealer_otp_sessions/{phone} {
      allow read, write: if false;
    }

    match /loginIndex/{loginKey} {
      allow read: if isActiveUser() && (isOpsUser() || isDealer());
      allow create: if isActiveUser()
        && (isOpsUser() || isDealer())
        && request.resource.data.uid is string
        && request.resource.data.role is string
        && request.resource.data.loginIdType is string
        && validLoginIdType(request.resource.data.loginIdType);
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isActiveUser() && (
        isOpsUser()
        || request.auth.uid == userId
        || (isDealer() && userDealerId(resource.data) == request.auth.uid)
        || (isDealerStaffRole(role()) && userDealerId(resource.data) == userDealerId(userDoc()))
      );

      allow create: if signedIn() && (
        (bootstrapOpen()
          && request.auth.uid == userId
          && (request.resource.data.role == 'super_admin' || request.resource.data.role == 'admin')
          && request.resource.data.active == true
          && validAadhar(request.resource.data))
        || (isActiveUser() && isSuperAdmin() && validAadhar(request.resource.data))
        || (isActiveUser()
            && isStaff()
            && staffCanManageRole(request.resource.data.role)
            && request.resource.data.active == true
            && validAadhar(request.resource.data))
        || (isActiveUser()
            && isDealer()
            && isDealerStaffRole(request.resource.data.role)
            && userDealerId(request.resource.data) == request.auth.uid
            && request.resource.data.active == true
            && validAadhar(request.resource.data))
      );

      allow update: if isActiveUser() && (
        isSuperAdmin()
        || (isStaff()
            && staffCanManageRole(resource.data.role)
            && staffCanManageRole(request.resource.data.role)
            && resource.data.role == request.resource.data.role
            && loginIdUnchanged())
        || (request.auth.uid == userId
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['role', 'loginId', 'loginIdType', 'aadhar', 'email', 'dealerId', 'directorId', 'active', 'createdAt', 'createdByUid']))
        || (isDealer()
            && isDealerStaffRole(resource.data.role)
            && userDealerId(resource.data) == request.auth.uid
            && isDealerStaffRole(request.resource.data.role)
            && userDealerId(request.resource.data) == request.auth.uid)
      );

      allow delete: if isSuperAdmin();
    }

    function isDealerStaff() {
      return signedIn() && isDealerStaffRole(role());
    }

    function validServiceRequestCreate() {
      let data = request.resource.data;
      return data.requestNumber is string
        && data.requestNumber.size() > 0
        && data.status == 'pending'
        && data.invoiceId is string
        && data.invoiceNumber is string
        && data.item is map
        && data.item.lineItemId is string
        && data.item.name is string
        && data.issue is string
        && data.issue.size() > 0
        && data.createdAt is string
        && data.createdByUid == request.auth.uid
        && data.createdByName is string
        && data.dealerId is string
        && (
          (isDealer() && data.dealerId == request.auth.uid)
          || (isDealerStaff() && data.dealerId == userDealerId(userDoc()))
        );
    }

    function validDealerSupportCreate() {
      let data = request.resource.data;
      return data.type is string
        && (data.type == 'service' || data.type == 'return' || data.type == 'complaint')
        && data.requestNumber is string
        && data.requestNumber.size() > 0
        && data.status == 'pending'
        && data.category is string
        && data.category.size() > 0
        && data.description is string
        && data.description.size() > 0
        && data.createdAt is string
        && data.createdByUid == request.auth.uid
        && data.createdByName is string
        && data.dealerId is string
        && (
          (isDealer() && data.dealerId == request.auth.uid)
          || (isDealerStaff() && data.dealerId == userDealerId(userDoc()))
        );
    }

    match /dealerSupportRequests/{requestId} {
      allow read: if isActiveUser() && (
        isOpsUser()
        || (isDealer() && resource.data.dealerId == request.auth.uid)
        || (isDealerStaff() && resource.data.dealerId == userDealerId(userDoc()))
      );

      allow create: if isActiveUser()
        && (isDealer() || isDealerStaff())
        && validDealerSupportCreate();

      allow update: if isActiveUser() && (
        isOpsUser()
        || (
          isSupportRequestDealerAccess(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['updatedAt', 'lastMessageAt', 'lastMessagePreview'])
        )
      );

      allow delete: if isSuperAdmin();

      match /messages/{messageId} {
        allow read: if isActiveUser() && canReadSupportRequest(requestId);

        allow create: if isActiveUser()
          && canReadSupportRequest(requestId)
          && canWriteSupportMessage(requestId)
          && validSupportMessageCreate();

        allow update, delete: if false;
      }
    }

    function canReadSupportRequest(requestId) {
      let req = get(/databases/$(database)/documents/dealerSupportRequests/$(requestId)).data;
      return isOpsUser()
        || (isDealer() && req.dealerId == request.auth.uid)
        || (isDealerStaff() && req.dealerId == userDealerId(userDoc()));
    }

    function isSupportRequestDealerAccess(data) {
      return (isDealer() && data.dealerId == request.auth.uid)
        || (isDealerStaff() && data.dealerId == userDealerId(userDoc()));
    }

    function canWriteSupportMessage(requestId) {
      let req = get(/databases/$(database)/documents/dealerSupportRequests/$(requestId)).data;
      return isOpsUser() || req.status != 'cancelled';
    }

    function validSupportMessageCreate() {
      let data = request.resource.data;
      return data.authorUid == request.auth.uid
        && data.authorName is string
        && data.authorRole is string
        && data.createdAt is string
        && data.text is string
        && data.attachments is list;
    }

    match /serviceRequests/{requestId} {
      allow read: if isActiveUser() && (
        isOpsUser()
        || (isDealer() && resource.data.dealerId == request.auth.uid)
        || (isDealerStaff() && resource.data.dealerId == userDealerId(userDoc()))
      );

      allow create: if isActiveUser()
        && (isDealer() || isDealerStaff())
        && validServiceRequestCreate();

      allow update: if isActiveUser() && isOpsUser();

      allow delete: if isSuperAdmin();
    }
  }
}
