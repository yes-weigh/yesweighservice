rules_version = '2';
// CI smoke-test marker — 2026-06-26

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return userDoc().role;
    }

    function isSuperAdmin() {
      return signedIn() && userExists() && (role() == 'super_admin' || role() == 'admin');
    }

    function isStaff() {
      return signedIn() && userExists() && role() == 'staff';
    }

    function isWarehouse() {
      return signedIn() && userExists() && role() == 'warehouse';
    }

    function isMedia() {
      return signedIn() && userExists() && role() == 'media';
    }

    function isOpsUser() {
      return isSuperAdmin() || isStaff();
    }

    function canWriteCatalogMedia() {
      return isSuperAdmin() || isMedia();
    }

    function canAccessYesStore() {
      return isWarehouse() || isSuperAdmin();
    }

    function isDealer() {
      return signedIn() && (role() == 'dealer' || role() == 'director');
    }

    function isActiveUser() {
      return signedIn() && userExists() && (
        isSuperAdmin()
        || userDoc().active != false
      );
    }

    function bootstrapOpen() {
      return !exists(/databases/$(database)/documents/appSettings/system)
        || get(/databases/$(database)/documents/appSettings/system).data.bootstrapComplete != true;
    }

    function staffCanManageRole(targetRole) {
      return targetRole == 'dealer' || targetRole == 'dealer_staff'
        || targetRole == 'director' || targetRole == 'director_staff';
    }

    function userDealerId(data) {
      return data.dealerId != null ? data.dealerId : data.directorId;
    }

    function isDealerStaffRole(r) {
      return r == 'dealer_staff' || r == 'director_staff';
    }

    function validLoginIdType(t) {
      return t == 'aadhar' || t == 'phone' || t == 'email' || t == 'username';
    }

    function validLoginId(data) {
      return data.loginId is string
        && data.loginIdType is string
        && validLoginIdType(data.loginIdType)
        && (
          (data.loginIdType == 'aadhar' && data.loginId.size() == 12)
          || (data.loginIdType == 'phone' && data.loginId.size() == 10)
          || (data.loginIdType == 'email' && data.loginId.matches('^[^@]+@[^@]+\\.[^@]+$'))
          || (data.loginIdType == 'username'
              && data.loginId.size() >= 2
              && data.loginId.size() <= 32
              && data.loginId.matches('^[a-z0-9][a-z0-9.-]*[a-z0-9]$|^[a-z0-9]$'))
        );
    }

    function validAadhar(data) {
      return validLoginId(data) || (data.aadhar is string && data.aadhar.size() == 12);
    }

    function loginIdUnchanged() {
      return !resource.data.keys().hasAny(['loginId'])
        || (request.resource.data.loginId == resource.data.loginId
            && request.resource.data.loginIdType == resource.data.loginIdType);
    }

    function validStaffDepartment(d) {
      return d == 'sales' || d == 'service' || d == 'logistics' || d == 'admin';
    }

    function validStaffAccessMode(m) {
      return m == 'department' || m == 'custom' || m == 'role';
    }

    function validStaffLogisticsSite(site) {
      return site == null || site == 'cochin' || site == 'head_office';
    }

    function validStaffAccessFields(data) {
      return (!('staffDepartment' in data) || validStaffDepartment(data.staffDepartment))
        && (!('staffAccessMode' in data) || validStaffAccessMode(data.staffAccessMode))
        && (!('staffPermissions' in data) || data.staffPermissions is list)
        && (!('staffKamId' in data) || data.staffKamId == null || data.staffKamId is string)
        && (!('staffTeamId' in data) || data.staffTeamId == null || data.staffTeamId is string)
        && (!('staffRoleId' in data) || data.staffRoleId == null || data.staffRoleId is string)
        && (!('staffLogisticsSite' in data) || validStaffLogisticsSite(data.staffLogisticsSite));
    }

    function validDealerTier(t) {
      return t == 'standard' || t == 'director';
    }

    function validDealerAccessMode(m) {
      return m == 'tier' || m == 'custom';
    }

    function validDealerAccessFields(data) {
      return (!('dealerTier' in data) || validDealerTier(data.dealerTier))
        && (!('dealerAccessMode' in data) || validDealerAccessMode(data.dealerAccessMode))
        && (!('dealerPermissions' in data) || data.dealerPermissions is list);
    }

    function validDealerPortalUserWrite(data) {
      return (data.role != 'dealer' && data.role != 'dealer_staff' && data.role != 'director' && data.role != 'director_staff')
        || validDealerAccessFields(data);
    }

    function validStaffUserWrite(data) {
      return data.role == 'staff' ? validStaffAccessFields(data) : true;
    }

    function validManagedUserWrite(data) {
      return validStaffUserWrite(data) && validDealerPortalUserWrite(data);
    }

    function validAadharId(aadhar) {
      return aadhar is string && aadhar.size() == 12;
    }

    function staffHasPermission(perm) {
      return isStaff()
        && userDoc().staffPermissions is list
        && perm in userDoc().staffPermissions;
    }

    function staffUsesExplicitPermissions() {
      let u = userDoc();
      return (u.staffAccessMode == 'custom' || u.staffAccessMode == 'role')
        && u.staffPermissions is list
        && u.staffPermissions.size() > 0;
    }

    function staffDepartmentGrantsHrManage() {
      return userDoc().staffDepartment == 'admin';
    }

    function staffDepartmentGrantsHrView() {
      return userDoc().staffDepartment == 'admin';
    }

    function staffHasHrManage() {
      return isStaff() && (
        (staffUsesExplicitPermissions() && staffHasPermission('hr.manage'))
        || (!staffUsesExplicitPermissions() && staffDepartmentGrantsHrManage())
      );
    }

    function staffHasHrView() {
      return isStaff() && (
        staffHasHrManage()
        || (staffUsesExplicitPermissions() && staffHasPermission('hr.view'))
        || (!staffUsesExplicitPermissions() && staffDepartmentGrantsHrView())
      );
    }

    match /appSettings/{docId} {
      allow read: if signedIn();
      allow write: if signedIn() && (
        bootstrapOpen()
        || (docId == 'productSettings' && isSuperAdmin())
        || (docId == 'logisticsSettings' && isSuperAdmin())
        || (docId == 'logisticsCourierRates' && isSuperAdmin())
        || (docId == 'localPrinterSettings' && isSuperAdmin())
        || (docId == 'labelStudio' && isSuperAdmin())
      );
    }

    match /catalogProducts/{productId} {
      allow read: if true;
      allow write: if false;

      match /auditLogs/{logId} {
        allow read: if isOpsUser() || isWarehouse();
        allow write: if false;
      }
    }

    match /catalogCategories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /catalogMeta/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /catalogProductSpareMap/{productId} {
      allow read: if true;
      allow write: if false;
    }

    match /zohoCustomers/{customerId} {
      allow read: if isOpsUser();
      allow write: if false;

      match /invoices/{invoiceId} {
        allow read: if isSuperAdmin();
        allow write: if false;
      }

      match /invoiceMeta/{docId} {
        allow read, write: if false;
      }

      match /invoiceSearch/{invoiceId} {
        allow read, write: if false;
      }
    }

    // Required for admin collectionGroup(db, 'invoices') live queries.
    match /{path=**}/invoices/{invoiceId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /invoiceIndex/{invoiceId} {
      allow read, write: if false;
    }

    match /invoiceMeta/{docId} {
      allow read, write: if false;
    }

    match /kams/{kamId} {
      allow read: if isOpsUser();
      allow write: if false;
    }

    match /staffRoles/{roleId} {
      allow read: if isActiveUser() && (isSuperAdmin() || staffHasHrView());
      allow create, update, delete: if isSuperAdmin();
    }

    match /hrHolidays/{holidayId} {
      allow read: if isActiveUser() && (isSuperAdmin() || staffHasHrView());
      allow create, update, delete: if isSuperAdmin() || staffHasHrManage();
    }

    match /dealerSettings/{docId} {
      allow read: if isOpsUser();
      allow write: if false;
    }

    match /aadharIndex/{aadhar} {
      allow read: if isActiveUser() && (isOpsUser() || isDealer());
      allow create: if validAadharId(aadhar)
        && isActiveUser()
        && (isOpsUser() || isDealer())
        && request.resource.data.uid is string
        && request.resource.data.role is string;
      allow delete: if isSuperAdmin();
    }

    match /dealer_otp_sessions/{phone} {
      allow read, write: if false;
    }

    match /loginIndex/{loginKey} {
      allow read: if isActiveUser() && (isOpsUser() || isDealer());
      allow create: if isActiveUser()
        && (isOpsUser() || isDealer())
        && request.resource.data.uid is string
        && request.resource.data.role is string
        && request.resource.data.loginIdType is string
        && validLoginIdType(request.resource.data.loginIdType);
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isActiveUser() && (
        isOpsUser()
        || request.auth.uid == userId
        || (isDealer() && userDealerId(resource.data) == request.auth.uid)
        || (isDealerStaffRole(role()) && userDealerId(resource.data) == userDealerId(userDoc()))
      );

      allow create: if signedIn() && (
        (bootstrapOpen()
          && request.auth.uid == userId
          && (request.resource.data.role == 'super_admin' || request.resource.data.role == 'admin')
          && request.resource.data.active == true
          && validAadhar(request.resource.data))
        || (isActiveUser() && isSuperAdmin() && validAadhar(request.resource.data) && validManagedUserWrite(request.resource.data))
        || (isActiveUser()
            && staffHasHrManage()
            && request.resource.data.role == 'staff'
            && request.resource.data.active == true
            && validAadhar(request.resource.data)
            && validStaffUserWrite(request.resource.data))
        || (isActiveUser()
            && staffHasHrManage()
            && request.resource.data.role == 'warehouse'
            && request.resource.data.active == true
            && validAadhar(request.resource.data))
        || (isActiveUser()
            && staffHasHrManage()
            && request.resource.data.role == 'media'
            && request.resource.data.active == true
            && validAadhar(request.resource.data))
        || (isActiveUser()
            && isStaff()
            && staffCanManageRole(request.resource.data.role)
            && request.resource.data.active == true
            && validAadhar(request.resource.data)
            && validDealerPortalUserWrite(request.resource.data))
        || (isDealer()
            && isDealerStaffRole(request.resource.data.role)
            && userDealerId(request.resource.data) == request.auth.uid
            && request.resource.data.active == true
            && validAadhar(request.resource.data)
            && validDealerPortalUserWrite(request.resource.data))
      );

      allow update: if isActiveUser() && (
        (isSuperAdmin() && validManagedUserWrite(request.resource.data))
        || (staffHasHrManage()
            && resource.data.role == 'staff'
            && request.resource.data.role == 'staff'
            && loginIdUnchanged()
            && validStaffUserWrite(request.resource.data))
        || (staffHasHrManage()
            && resource.data.role == 'warehouse'
            && request.resource.data.role == 'warehouse'
            && loginIdUnchanged())
        || (staffHasHrManage()
            && resource.data.role == 'media'
            && request.resource.data.role == 'media'
            && loginIdUnchanged())
        || (isStaff()
            && staffCanManageRole(resource.data.role)
            && staffCanManageRole(request.resource.data.role)
            && resource.data.role == request.resource.data.role
            && loginIdUnchanged()
            && validDealerPortalUserWrite(request.resource.data))
        || (request.auth.uid == userId
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['role', 'loginId', 'loginIdType', 'aadhar', 'email', 'dealerId', 'directorId', 'active', 'createdAt', 'createdByUid']))
        || (isDealer()
            && isDealerStaffRole(resource.data.role)
            && userDealerId(resource.data) == request.auth.uid
            && isDealerStaffRole(request.resource.data.role)
            && userDealerId(request.resource.data) == request.auth.uid
            && validDealerPortalUserWrite(request.resource.data))
      );

      allow delete: if isSuperAdmin();
    }

    function isDealerStaff() {
      return signedIn() && isDealerStaffRole(role());
    }

    function isSupportDraftData(data) {
      return data.lifecycle == 'draft' || data.status == 'draft';
    }

    function isSupportOpenData(data) {
      return data.lifecycle == 'open'
        || data.status == 'pending'
        || data.status == 'awaiting_product'
        || data.status == 'in_progress';
    }

    function isSupportClosedData(data) {
      return data.lifecycle == 'resolved'
        || data.lifecycle == 'cancelled'
        || data.status == 'completed'
        || data.status == 'cancelled';
    }

    function validDealerSupportChatCreate() {
      let data = request.resource.data;
      return data.type == 'chat'
        && data.lifecycle == 'open'
        && data.openStage == 'submitted'
        && data.requestNumber is string
        && data.requestNumber.size() > 0
        && data.category == 'general'
        && data.description is string
        && data.createdAt is string
        && data.createdByUid == request.auth.uid
        && data.createdByName is string
        && data.dealerId is string
        && (
          (isDealer() && data.dealerId == request.auth.uid)
          || (isDealerStaff() && data.dealerId == userDealerId(userDoc()))
        );
    }

    function validDealerSupportDraftCreate() {
      let data = request.resource.data;
      return data.type is string
        && (data.type == 'service' || data.type == 'return' || data.type == 'complaint' || data.type == 'chat')
        && data.requestNumber is string
        && data.requestNumber.size() > 0
        && isSupportDraftData(data)
        && data.category is string
        && data.description is string
        && data.createdAt is string
        && data.createdByUid == request.auth.uid
        && data.createdByName is string
        && data.dealerId is string
        && (
          (isDealer() && data.dealerId == request.auth.uid)
          || (isDealerStaff() && data.dealerId == userDealerId(userDoc()))
        );
    }

    function validOpsSupportDraftCreate() {
      let data = request.resource.data;
      return isOpsUser()
        && data.type is string
        && (data.type == 'service' || data.type == 'return' || data.type == 'complaint')
        && data.requestNumber is string
        && data.requestNumber.size() > 0
        && isSupportDraftData(data)
        && data.category is string
        && data.description is string
        && data.createdAt is string
        && data.createdByUid == request.auth.uid
        && data.createdByName is string
        && data.dealerId is string
        && data.dealerName is string
        && data.zohoCustomerId is string
        && data.createdOnBehalfOf == true;
    }

    function validOpsSupportDraftUpdate() {
      let data = request.resource.data;
      return isOpsUser()
        && resource.data.createdOnBehalfOf == true
        && isSupportDraftData(resource.data)
        && isSupportDraftData(data)
        && dealerSupportImmutableFieldsMatch()
        && data.type is string
        && (data.type == 'service' || data.type == 'return' || data.type == 'complaint')
        && data.category is string
        && data.description is string
        && data.updatedAt is string
        && data.createdOnBehalfOf == true
        && data.zohoCustomerId is string;
    }

    function dealerSupportImmutableFieldsMatch() {
      let data = request.resource.data;
      let prev = resource.data;
      return data.dealerId == prev.dealerId
        && data.createdByUid == prev.createdByUid
        && data.createdAt == prev.createdAt
        && data.requestNumber == prev.requestNumber;
    }

    function validDealerSupportDraftUpdate() {
      let data = request.resource.data;
      return isSupportDraftData(resource.data)
        && isSupportDraftData(data)
        && dealerSupportImmutableFieldsMatch()
        && data.type is string
        && (data.type == 'service' || data.type == 'return' || data.type == 'complaint' || data.type == 'chat')
        && data.category is string
        && data.description is string
        && data.updatedAt is string;
    }

    function validDealerSupportSubmit() {
      let data = request.resource.data;
      return isSupportDraftData(resource.data)
        && data.lifecycle == 'open'
        && data.openStage == 'submitted'
        && dealerSupportImmutableFieldsMatch()
        && data.type is string
        && (data.type == 'service' || data.type == 'return' || data.type == 'complaint' || data.type == 'chat')
        && data.category is string
        && data.category.size() > 0
        && data.description is string
        && data.description.size() > 0
        && data.updatedAt is string;
    }

    function validDealerSupportMarkShipped() {
      let data = request.resource.data;
      return isSupportRequestDealerAccess(resource.data)
        && resource.data.lifecycle == 'open'
        && resource.data.openStage == 'awaiting_product'
        && data.lifecycle == 'open'
        && data.openStage == 'in_transit'
        && dealerSupportImmutableFieldsMatch()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lifecycle', 'openStage', 'courierTracking', 'shippedAt', 'updatedAt']);
    }

    function validDealerSupportCancel() {
      let data = request.resource.data;
      return isSupportRequestDealerAccess(resource.data)
        && resource.data.lifecycle == 'open'
        && (
          resource.data.openStage == 'submitted'
          || resource.data.openStage == 'under_review'
          || resource.data.openStage == 'awaiting_dealer'
        )
        && data.lifecycle == 'cancelled'
        && data.openStage == null
        && dealerSupportImmutableFieldsMatch()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lifecycle', 'openStage', 'updatedAt']);
    }

    function validDealerSupportMessageMetaUpdate() {
      return isSupportRequestDealerAccess(resource.data)
        && !isSupportClosedData(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['updatedAt', 'lastMessageAt', 'lastMessagePreview', 'openStage']);
    }

    match /dealerSupportRequests/{requestId} {
      allow read: if isActiveUser() && (
        isOpsUser()
        || (isDealer() && resource.data.dealerId == request.auth.uid)
        || (isDealerStaff() && resource.data.dealerId == userDealerId(userDoc()))
        || resource.data.createdByUid == request.auth.uid
      );

      allow create: if isActiveUser()
        && (
          ((isDealer() || isDealerStaff()) && (validDealerSupportDraftCreate() || validDealerSupportChatCreate()))
          || validOpsSupportDraftCreate()
        );

      allow update: if isActiveUser() && (
        isOpsUser()
        || validDealerSupportMessageMetaUpdate()
        || validOpsSupportDraftUpdate()
        || (
          isSupportRequestDealerAccess(resource.data)
          && validDealerSupportDraftUpdate()
        )
        || (
          isSupportRequestDealerAccess(resource.data)
          && validDealerSupportSubmit()
        )
        || validDealerSupportMarkShipped()
        || validDealerSupportCancel()
      );

      allow delete: if isSuperAdmin()
        || (
          isActiveUser()
          && isSupportRequestDealerAccess(resource.data)
          && isSupportDraftData(resource.data)
        );

      match /messages/{messageId} {
        allow read: if isActiveUser() && canReadSupportRequest(requestId);

        allow create: if isActiveUser()
          && canReadSupportRequest(requestId)
          && canWriteSupportMessage(requestId)
          && validSupportMessageCreate();

        allow update: if false;
        allow delete: if isSuperAdmin();
      }
    }

    function canReadSupportRequest(requestId) {
      let req = get(/databases/$(database)/documents/dealerSupportRequests/$(requestId)).data;
      return isOpsUser()
        || (isDealer() && req.dealerId == request.auth.uid)
        || (isDealerStaff() && req.dealerId == userDealerId(userDoc()))
        || req.createdByUid == request.auth.uid;
    }

    function isSupportRequestDealerAccess(data) {
      return (isDealer() && data.dealerId == request.auth.uid)
        || (isDealerStaff() && data.dealerId == userDealerId(userDoc()))
        || data.createdByUid == request.auth.uid;
    }

    function canWriteSupportMessage(requestId) {
      let req = get(/databases/$(database)/documents/dealerSupportRequests/$(requestId)).data;
      let msg = request.resource.data;
      return isOpsUser()
        || (req.lifecycle == 'open' && !isSupportClosedData(req))
        || (isSupportDraftData(req) && msg.isInitial == true && msg.authorUid == request.auth.uid);
    }

    function validSupportMessageCreate() {
      let data = request.resource.data;
      return data.authorUid == request.auth.uid
        && data.authorName is string
        && data.authorRole is string
        && data.createdAt is string
        && data.text is string
        && data.attachments is list;
    }

    match /yesStoreRacks/{rackId} {
      allow read, write: if canAccessYesStore();
    }

    match /yesStoreRows/{rowId} {
      allow read, write: if canAccessYesStore();
    }

    match /yesStoreBins/{binId} {
      allow read, write: if canAccessYesStore();
    }

    match /yesStoreItems/{itemId} {
      allow read, write: if canAccessYesStore();
    }

    match /warehouseZones/{zoneId} {
      allow read: if isOpsUser() || isWarehouse();
      allow write: if isSuperAdmin();
    }

    match /warehouseZoneRows/{rowId} {
      allow read: if isOpsUser() || isWarehouse();
      allow write: if isSuperAdmin();
    }

    match /catalogSiteInventory/{docId} {
      allow read: if isOpsUser() || isWarehouse();
      allow write: if isSuperAdmin() || isStaff();
    }

    match /auditCycles/{cycleId} {
      allow read: if isOpsUser() || isWarehouse();
      allow write: if isSuperAdmin();
    }

    match /catalogProductNc/{productId} {
      allow read: if isOpsUser();
      allow write: if isSuperAdmin() || isStaff();
    }

    match /catalogProductMedia/{productId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser() && canWriteCatalogMedia();
    }

    function isLogisticsBookingDealerAccess(data) {
      return (isDealer() && (
          data.dealerId == request.auth.uid
          || (userDoc().keys().hasAny(['zohoCustomerId'])
              && data.zohoCustomerId == userDoc().zohoCustomerId)
        ))
        || (isDealerStaff() && data.dealerId == userDealerId(userDoc()));
    }

    function validLogisticsBookingCreate() {
      let data = request.resource.data;
      return isOpsUser()
        && data.partnerId is string
        && data.consignmentNo is string
        && (
          data.consignmentNo.size() > 0
          || (data.keys().hasAny(['wizardStep']) && data.wizardStep is string && data.wizardStep.size() > 0)
        )
        && data.zohoCustomerId is string
        && data.dealerId is string
        && data.dealerSnapshot is map
        && (
          data.status == 'label_generated'
          || data.status == 'shipped'
          || data.status == 'in_transit'
          || data.status == 'delivered'
          || data.status == 'cancelled'
        )
        && data.createdByUid == request.auth.uid
        && data.createdAt is string
        && data.updatedAt is string;
    }

    function validLogisticsBookingOpsUpdate() {
      return isOpsUser()
        && request.resource.data.dealerId == resource.data.dealerId
        && request.resource.data.zohoCustomerId == resource.data.zohoCustomerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdByUid == resource.data.createdByUid;
    }

    match /logisticsBookings/{bookingId} {
      allow read: if isActiveUser() && (
        isOpsUser()
        || isLogisticsBookingDealerAccess(resource.data)
      );

      allow create: if isActiveUser() && validLogisticsBookingCreate();

      allow update: if isActiveUser() && isOpsUser() && validLogisticsBookingOpsUpdate();

      allow delete: if isSuperAdmin();
    }
  }
}
