rules_version = '2';
// CI smoke-test marker — 2026-06-26

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function role() {
      return userDoc().role;
    }

    function isSuperAdmin() {
      return signedIn() && userExists() && (role() == 'super_admin' || role() == 'admin');
    }

    function isStaff() {
      return signedIn() && userExists() && role() == 'staff';
    }

    function isOpsUser() {
      return isSuperAdmin() || isStaff();
    }

    function isActivePortalUser() {
      return signedIn() && userExists() && (
        isSuperAdmin()
        || userDoc().active != false
      );
    }

    function userDealerId(data) {
      return data.dealerId != null ? data.dealerId : data.directorId;
    }

    function resolvedDealerIdForUser() {
      let data = userDoc();
      return role() == 'dealer' || role() == 'director'
        ? request.auth.uid
        : (role() == 'dealer_staff' || role() == 'director_staff'
          ? (userDealerId(data) != null ? userDealerId(data) : request.auth.uid)
          : null);
    }

    function canAccessSupportRequest(requestId) {
      let path = /databases/(default)/documents/dealerSupportRequests/$(requestId);
      let req = firestore.get(path).data;
      return firestore.exists(path)
        && isActivePortalUser()
        && (
          isOpsUser()
          || req.dealerId == resolvedDealerIdForUser()
          || req.createdByUid == request.auth.uid
        );
    }

    function validSupportMedia() {
      return request.resource.size < 52 * 1024 * 1024
        && (
          request.resource.contentType == null
          || request.resource.contentType == ''
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
          || request.resource.contentType == 'application/octet-stream'
        );
    }

    function staffHasPermission(perm) {
      return isStaff()
        && userDoc().staffPermissions is list
        && perm in userDoc().staffPermissions;
    }

    function staffUsesExplicitPermissions() {
      let u = userDoc();
      return (u.staffAccessMode == 'custom' || u.staffAccessMode == 'role')
        && u.staffPermissions is list
        && u.staffPermissions.size() > 0;
    }

    function staffDepartmentGrantsHrManage() {
      return userDoc().staffDepartment == 'admin';
    }

    function staffDepartmentGrantsHrView() {
      return userDoc().staffDepartment == 'admin';
    }

    function staffHasHrManage() {
      return isStaff() && (
        (staffUsesExplicitPermissions() && staffHasPermission('hr.manage'))
        || (!staffUsesExplicitPermissions() && staffDepartmentGrantsHrManage())
      );
    }

    function staffHasHrView() {
      return isStaff() && (
        staffHasHrManage()
        || (staffUsesExplicitPermissions() && staffHasPermission('hr.view'))
        || (!staffUsesExplicitPermissions() && staffDepartmentGrantsHrView())
      );
    }

    function validHrMedia() {
      return request.resource.size < 16 * 1024 * 1024
        && (
          request.resource.contentType == null
          || request.resource.contentType == ''
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'application/octet-stream'
        );
    }

    match /catalog/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /catalogNc/{productId}/{fileName} {
      allow read: if true;
      allow create, update: if isOpsUser() && validSupportMedia();
      allow delete: if isOpsUser();
    }

    match /catalogMedia/{productId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Written only via Admin SDK (uploadApprovalNumberPdfFn / removeApprovalNumberPdfFn).
    match /productSettings/approvalPdfs/{fileName} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /invoices/{allPaths=**} {
      allow read, write: if false;
    }

    match /support/{requestId}/{messageId}/{fileName} {
      allow read: if canAccessSupportRequest(requestId);
      allow write: if canAccessSupportRequest(requestId) && validSupportMedia();
    }

    match /hr/{userId}/{allPaths=**} {
      allow read: if signedIn() && userExists() && (
        isSuperAdmin()
        || (userDoc().active != false && (
          request.auth.uid == userId
          || staffHasHrView()
        ))
      );
      allow write: if signedIn() && userExists() && validHrMedia() && (
        isSuperAdmin()
        || (userDoc().active != false && staffHasHrManage())
      );
    }

    function validYesStoreImage() {
      return request.resource != null
        && request.resource.size < 12 * 1024 * 1024
        && (
          request.resource.contentType == null
          || request.resource.contentType == ''
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/octet-stream'
        );
    }

    /** YesStore only — do not reuse HR/support helpers here. */
    function canYesStoreUser() {
      return signedIn() && userExists() && userDoc().active != false && (
        role() == 'warehouse' || role() == 'super_admin' || role() == 'admin'
      );
    }

    match /yesStore/{level}/{parentId}/{fileName} {
      allow read: if canYesStoreUser();
      allow create, update: if canYesStoreUser() && validYesStoreImage();
      allow delete: if canYesStoreUser();
    }

    function canAccessLogisticsBooking(bookingId) {
      let path = /databases/(default)/documents/logisticsBookings/$(bookingId);
      return firestore.exists(path)
        && isActivePortalUser()
        && (
          isOpsUser()
          || firestore.get(path).data.dealerId == resolvedDealerIdForUser()
          || (userDoc().keys().hasAny(['zohoCustomerId'])
              && firestore.get(path).data.zohoCustomerId == userDoc().zohoCustomerId)
        );
    }

    function canWriteLogisticsPhoto(bookingId) {
      return validSupportMedia() && (
        isOpsUser()
        // After the booking stub exists, ops/dealer access also unlocks uploads.
        || canAccessLogisticsBooking(bookingId)
      );
    }

    // Nested paths used by the client: logistics/{bookingId}/{slot}/{fileName}
    match /logistics/{bookingId}/{slot}/{fileName} {
      allow read: if isOpsUser() || canAccessLogisticsBooking(bookingId);
      allow create, update: if canWriteLogisticsPhoto(bookingId);
      allow delete: if isOpsUser();
    }

    // Flat legacy paths: logistics/{bookingId}/{fileName}
    match /logistics/{bookingId}/{fileName} {
      allow read: if isOpsUser() || canAccessLogisticsBooking(bookingId);
      allow create, update: if canWriteLogisticsPhoto(bookingId);
      allow delete: if isOpsUser();
    }

    /** Temporary product share cards — public read so WhatsApp can fetch the image. */
    match /whatsappShares/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isActivePortalUser()
        && request.auth.uid == userId
        && request.resource.size < 4 * 1024 * 1024
        && (
          request.resource.contentType == null
          || request.resource.contentType == ''
          || request.resource.contentType.matches('image/.*')
        );
      allow delete: if signedIn() && request.auth.uid == userId;
    }
  }
}
