rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function role() {
      return userDoc().role;
    }

    function isSuperAdmin() {
      return signedIn() && userExists() && (role() == 'super_admin' || role() == 'admin');
    }

    function isStaff() {
      return signedIn() && userExists() && role() == 'staff';
    }

    function isOpsUser() {
      return isSuperAdmin() || isStaff();
    }

    function isActivePortalUser() {
      return signedIn() && userExists() && (
        isSuperAdmin()
        || userDoc().active != false
      );
    }

    function userDealerId(data) {
      return data.dealerId != null ? data.dealerId : data.directorId;
    }

    function resolvedDealerIdForUser() {
      let data = userDoc();
      return role() == 'dealer' || role() == 'director'
        ? request.auth.uid
        : (role() == 'dealer_staff' || role() == 'director_staff'
          ? (userDealerId(data) != null ? userDealerId(data) : request.auth.uid)
          : null);
    }

    function canAccessSupportRequest(requestId) {
      let path = /databases/(default)/documents/dealerSupportRequests/$(requestId);
      let req = firestore.get(path).data;
      return firestore.exists(path)
        && isActivePortalUser()
        && (
          isOpsUser()
          || req.dealerId == resolvedDealerIdForUser()
          || req.createdByUid == request.auth.uid
        );
    }

    function validSupportMedia() {
      return request.resource.size < 52 * 1024 * 1024
        && (
          request.resource.contentType == null
          || request.resource.contentType == ''
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
          || request.resource.contentType == 'application/octet-stream'
        );
    }

    function staffHasPermission(perm) {
      return isStaff()
        && userDoc().staffPermissions is list
        && perm in userDoc().staffPermissions;
    }

    function staffUsesExplicitPermissions() {
      let u = userDoc();
      return (u.staffAccessMode == 'custom' || u.staffAccessMode == 'role')
        && u.staffPermissions is list
        && u.staffPermissions.size() > 0;
    }

    function staffDepartmentGrantsHrManage() {
      return userDoc().staffDepartment == 'admin';
    }

    function staffDepartmentGrantsHrView() {
      return userDoc().staffDepartment == 'admin';
    }

    function staffHasHrManage() {
      return isStaff() && (
        (staffUsesExplicitPermissions() && staffHasPermission('hr.manage'))
        || (!staffUsesExplicitPermissions() && staffDepartmentGrantsHrManage())
      );
    }

    function staffHasHrView() {
      return isStaff() && (
        staffHasHrManage()
        || (staffUsesExplicitPermissions() && staffHasPermission('hr.view'))
        || (!staffUsesExplicitPermissions() && staffDepartmentGrantsHrView())
      );
    }

    function validHrMedia() {
      return request.resource.size < 16 * 1024 * 1024
        && (
          request.resource.contentType == null
          || request.resource.contentType == ''
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'application/octet-stream'
        );
    }

    match /catalog/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /invoices/{allPaths=**} {
      allow read, write: if false;
    }

    match /support/{requestId}/{messageId}/{fileName} {
      allow read: if canAccessSupportRequest(requestId);
      allow write: if canAccessSupportRequest(requestId) && validSupportMedia();
    }

    match /hr/{userId}/{allPaths=**} {
      allow read: if signedIn() && userExists() && (
        isSuperAdmin()
        || (userDoc().active != false && (
          request.auth.uid == userId
          || staffHasHrView()
        ))
      );
      allow write: if signedIn() && userExists() && validHrMedia() && (
        isSuperAdmin()
        || (userDoc().active != false && staffHasHrManage())
      );
    }
  }
}
